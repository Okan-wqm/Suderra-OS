#
# Suderra OS — BR2_EXTERNAL Kconfig giriş noktası
#
# Bu dosya `make menuconfig` çalıştırıldığında "External options"
# menüsünde Suderra OS-özel seçeneklerini ortaya çıkarır.
#
# Buildroot manuel:
#   https://buildroot.org/downloads/manual/manual.html#outside-br-custom
#

menu "Suderra OS"

config BR2_EXTERNAL_SUDERRA_PATH
	string
	default "$(BR2_EXTERNAL_SUDERRA_PATH)"

#
# Custom paketler — package/<name>/Config.in dosyaları
#
source "$BR2_EXTERNAL_SUDERRA_PATH/package/suderra-edge-agent/Config.in"
source "$BR2_EXTERNAL_SUDERRA_PATH/package/suderra-firstboot/Config.in"
source "$BR2_EXTERNAL_SUDERRA_PATH/package/suderra-os-installer/Config.in"
source "$BR2_EXTERNAL_SUDERRA_PATH/package/suderra-keys/Config.in"

#
# Profil seçimi — hangi varyant build ediliyor
#
choice
	prompt "Suderra OS variant"
	default BR2_PACKAGE_SUDERRA_VARIANT_PROD

config BR2_PACKAGE_SUDERRA_VARIANT_DEV
	bool "Development / diagnostics (not for appliance release)"
	help
	  Sadece kontrollü geliştirme ve QEMU/lab doğrulaması için.
	  Production'da KULLANMA.

config BR2_PACKAGE_SUDERRA_VARIANT_PROD
	bool "Production appliance (provision, then Suderra agent only)"
	help
	  Üretim varyantı local console provisioning ile başlar. Edge
	  artifact kurulunca suderra-lockdown root login, getty, debug shell
	  ve remote shell servislerini kapatır; runtime'da sadece zorunlu
	  sistem servisleri ve suderra-agent çalışır.
	  dm-verity, secure boot, imzalı release ve RAUC üretim kapılarıdır.

endchoice

#
# Versiyon bilgisi (os-release dosyasına yazılır)
#
config BR2_PACKAGE_SUDERRA_VERSION
	string "Suderra OS version string"
	default "v0.1.0-alpha"

config BR2_PACKAGE_SUDERRA_BUILD_ID
	string "Build identifier (CI/CD pipeline'dan gelir)"
	default "local-dev"

endmenu
