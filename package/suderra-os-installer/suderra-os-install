#!/bin/sh
set -eu

PAYLOAD_DIR="${SUDERRA_INSTALLER_PAYLOAD_DIR:-/run/suderra-installer/payload}"
SYS_BLOCK="${SUDERRA_INSTALLER_SYS_BLOCK:-/sys/block}"
DEV_DIR="${SUDERRA_INSTALLER_DEV_DIR:-/dev}"
PROC_MODEL="${SUDERRA_INSTALLER_PROC_MODEL:-/proc/device-tree/model}"
PROC_COMPATIBLE="${SUDERRA_INSTALLER_PROC_COMPATIBLE:-/proc/device-tree/compatible}"
PUBKEY="${SUDERRA_INSTALLER_PUBKEY:-/etc/suderra/os-installer-payload.ed25519.pub}"
VERIFY_BIN="${SUDERRA_INSTALLER_VERIFY_BIN:-/usr/bin/suderra-installer}"
MIN_BYTES="${SUDERRA_INSTALLER_MIN_BYTES:-8589934592}"
ALLOW_USB_TARGET="${SUDERRA_INSTALLER_ALLOW_USB_TARGET:-0}"
USB_TARGET_BY_ID="${SUDERRA_INSTALLER_USB_TARGET_BY_ID:-}"
SOURCE_DISK="${SUDERRA_INSTALLER_SOURCE_DISK:-}"
ASSUME_YES="${SUDERRA_INSTALLER_ASSUME_YES:-0}"
DRY_RUN="${SUDERRA_INSTALLER_DRY_RUN:-0}"
REPORT_DIR="${SUDERRA_INSTALLER_REPORT_DIR:-/run/suderra-installer}"
PLAN_FILE="${REPORT_DIR}/payload-plan.env"
TARGET_BOARD="${SUDERRA_INSTALLER_TARGET_BOARD:-}"
MIN_KEY_EPOCH="${SUDERRA_INSTALLER_MIN_KEY_EPOCH:-1}"
MIN_ROLLBACK_FLOOR="${SUDERRA_INSTALLER_MIN_ROLLBACK_FLOOR:-v0.1.0-alpha}"
TARGET_ARCH="${SUDERRA_INSTALLER_TARGET_ARCH:-$(uname -m)}"

usage() {
    cat <<'EOF'
Usage:
  suderra-os-install --install [--yes]
  suderra-os-install --select-target
  suderra-os-install --verify-payload

The installer verifies an Ed25519-signed payload index, target image SHA256,
compressed/uncompressed size, and board compatibility through the Rust
suderra-installer verifier. It excludes its own boot/payload disks, selects
eMMC before SD, and only writes a USB target when an explicit
SUDERRA_INSTALLER_USB_TARGET_BY_ID=/dev/disk/by-id/... path is provided.
EOF
}

log() {
    printf '%s\n' "$*"
}

die() {
    printf 'ERROR: %s\n' "$*" >&2
    exit 1
}

detect_target_board() {
    if [ -n "${TARGET_BOARD}" ]; then
        case "${TARGET_BOARD}" in
            rpi4-cm4|revpi4)
                printf '%s\n' "${TARGET_BOARD}"
                return 0
                ;;
            *)
                die "unsupported explicit target board: ${TARGET_BOARD}"
                ;;
        esac
    fi

    if [ -r "${PROC_MODEL}" ]; then
        model="$(tr -d '\000' < "${PROC_MODEL}")"
        case "${model}" in
            *RevPi\ Connect\ 4*|*Revolution\ Pi\ Connect\ 4*)
                printf '%s\n' "revpi4"
                return 0
                ;;
        esac
    fi

    if [ -r "${PROC_COMPATIBLE}" ]; then
        if tr '\000' '\n' < "${PROC_COMPATIBLE}" | grep -Eiq '(revpi|revolution[- ]?pi|kunbus)'; then
            printf '%s\n' "revpi4"
            return 0
        fi
    fi

    if [ -r "${PROC_MODEL}" ]; then
        model="$(tr -d '\000' < "${PROC_MODEL}")"
        case "${model}" in
            Raspberry\ Pi\ 4\ Model\ B*|*Raspberry\ Pi\ 4\ Model\ B*)
                printf '%s\n' "rpi4-cm4"
                return 0
                ;;
            Raspberry\ Pi\ Compute\ Module\ 4*|*Raspberry\ Pi\ Compute\ Module\ 4*)
                die "ambiguous Compute Module 4 target; set SUDERRA_INSTALLER_TARGET_BOARD=rpi4-cm4 or revpi4 after board identity evidence"
                ;;
        esac
    fi

    die "could not determine target board; set SUDERRA_INSTALLER_TARGET_BOARD"
}

ensure_payload_mounted() {
    if [ -f "${PAYLOAD_DIR}/manifest.json" ]; then
        return 0
    fi

    mkdir -p "${PAYLOAD_DIR}"
    if command -v mount >/dev/null 2>&1; then
        mount -o ro -L SUDERRA-PAYLOAD "${PAYLOAD_DIR}" 2>/dev/null || true
    fi

    [ -f "${PAYLOAD_DIR}/manifest.json" ] ||
        die "payload manifest not found in ${PAYLOAD_DIR}"
}

verify_payload() {
    ensure_payload_mounted

    [ -x "${VERIFY_BIN}" ] || die "suderra-installer verifier missing: ${VERIFY_BIN}"
    [ -s "${PUBKEY}" ] || die "pinned installer public key missing: ${PUBKEY}"

    board="$(detect_target_board)"
    mkdir -p "${REPORT_DIR}"
    log "==> Verifying signed installer payload for ${board}"
    "${VERIFY_BIN}" usb-payload verify \
        --payload-dir "${PAYLOAD_DIR}" \
        --public-key "${PUBKEY}" \
        --target-board "${board}" \
        --target-arch "${TARGET_ARCH}" \
        --min-key-epoch "${MIN_KEY_EPOCH}" \
        --min-rollback-floor "${MIN_ROLLBACK_FLOOR}" \
        --write-plan "${PLAN_FILE}"

    # shellcheck disable=SC1090
    . "${PLAN_FILE}"
    [ -n "${SUDERRA_PAYLOAD_IMAGE_PATH:-}" ] ||
        die "verifier did not write SUDERRA_PAYLOAD_IMAGE_PATH"

    log "==> Payload verified: ${SUDERRA_PAYLOAD_IMAGE_NAME}"
}

disk_from_partition() {
    partition="$1"
    base="$(basename "${partition}")"
    case "${base}" in
        mmcblk*p[0-9]*)
            printf '%s\n' "${base%p[0-9]*}"
            ;;
        sd*[0-9]*)
            printf '%s\n' "${base%[0-9]*}"
            ;;
        nvme*n*p[0-9]*)
            printf '%s\n' "${base%p[0-9]*}"
            ;;
        *)
            printf '%s\n' "${base}"
            ;;
    esac
}

source_disk() {
    if [ -n "${SOURCE_DISK}" ]; then
        basename "${SOURCE_DISK}"
        return 0
    fi

    root_source="$(findmnt -n -o SOURCE / 2>/dev/null || true)"
    if [ "${root_source}" = "/dev/root" ]; then
        root_source="$(readlink -f /dev/root 2>/dev/null || printf '%s\n' /dev/root)"
    fi
    if [ -n "${root_source}" ] && [ "${root_source#"${DEV_DIR}"/}" != "${root_source}" ]; then
        parent="$(lsblk -n -o PKNAME "${root_source}" 2>/dev/null | head -n 1 || true)"
        if [ -n "${parent}" ]; then
            printf '%s\n' "${parent}"
        else
            disk_from_partition "${root_source}"
        fi
        return 0
    fi

    die "could not determine installer source disk; set SUDERRA_INSTALLER_SOURCE_DISK"
}

mounted_disk_for_path() {
    path="$1"
    source="$(findmnt -n -o SOURCE "${path}" 2>/dev/null || true)"
    [ -n "${source}" ] || return 0
    case "${source}" in
        /dev/root)
            source="$(readlink -f /dev/root 2>/dev/null || printf '%s\n' /dev/root)"
            ;;
    esac
    [ "${source#"${DEV_DIR}"/}" != "${source}" ] || return 0
    parent="$(lsblk -n -o PKNAME "${source}" 2>/dev/null | head -n 1 || true)"
    if [ -n "${parent}" ]; then
        printf '%s\n' "${parent}"
    else
        disk_from_partition "${source}"
    fi
}

excluded_disks() {
    source_disk
    mounted_disk_for_path /boot
    mounted_disk_for_path "${PAYLOAD_DIR}"
}

is_excluded_disk() {
    name="$1"
    for excluded in $(excluded_disks | sort -u); do
        [ "${name}" != "${excluded}" ] || return 0
    done
    return 1
}

read_sys_value() {
    file="$1"
    default="$2"
    if [ -r "${file}" ]; then
        tr -d '[:space:]' < "${file}"
    else
        printf '%s\n' "${default}"
    fi
}

candidate_priority() {
    name="$1"
    removable="$2"
    media_type="$3"
    case "${name}" in
        mmcblk*)
            if [ "${removable}" = "0" ] || [ "${media_type}" = "MMC" ]; then
                printf '0\n'
            else
                printf '1\n'
            fi
            ;;
        sd*)
            printf '9\n'
            ;;
        *)
            printf '9\n'
            ;;
    esac
}

select_target() {
    if [ "${ALLOW_USB_TARGET}" = "1" ] && [ -n "${USB_TARGET_BY_ID}" ]; then
        case "${USB_TARGET_BY_ID}" in
            /dev/disk/by-id/*|"${DEV_DIR}"/disk/by-id/*)
                ;;
            *)
                die "USB targets must be explicit /dev/disk/by-id paths"
                ;;
        esac
        [ -e "${USB_TARGET_BY_ID}" ] ||
            die "explicit USB target does not exist: ${USB_TARGET_BY_ID}"
        resolved="$(readlink -f "${USB_TARGET_BY_ID}" 2>/dev/null || printf '%s\n' "${USB_TARGET_BY_ID}")"
        name="$(basename "${resolved}")"
        is_excluded_disk "${name}" &&
            die "explicit USB target is an installer source disk: ${USB_TARGET_BY_ID}"
        devpath="${SYS_BLOCK}/${name}"
        [ -e "${devpath}" ] || die "explicit USB target is not in ${SYS_BLOCK}: ${name}"
        removable="$(read_sys_value "${devpath}/removable" "0")"
        by_id_name="$(basename "${USB_TARGET_BY_ID}")"
        case "${by_id_name}" in
            usb-*)
                ;;
            *)
                [ "${removable}" = "1" ] ||
                    die "explicit USB target must use a usb-* by-id path or a removable whole disk"
                ;;
        esac
        sectors="$(read_sys_value "${devpath}/size" "0")"
        bytes=$((sectors * 512))
        [ "${bytes}" -ge "${MIN_BYTES}" ] ||
            die "explicit USB target is smaller than minimum ${MIN_BYTES} bytes"
        printf '%s\n' "${USB_TARGET_BY_ID}"
        return 0
    fi

    best_name=""
    best_priority=99
    best_count=0
    candidates=0

    for devpath in "${SYS_BLOCK}"/mmcblk* "${SYS_BLOCK}"/sd*; do
        [ -e "${devpath}" ] || continue
        name="$(basename "${devpath}")"

        case "${name}" in
            *boot*|*rpmb*) continue ;;
        esac

        is_excluded_disk "${name}" && continue

        case "${name}" in
            sd*) continue ;;
        esac

        sectors="$(read_sys_value "${devpath}/size" "0")"
        removable="$(read_sys_value "${devpath}/removable" "1")"
        media_type="$(read_sys_value "${devpath}/device/type" "")"
        bytes=$((sectors * 512))
        [ "${bytes}" -ge "${MIN_BYTES}" ] || continue

        priority="$(candidate_priority "${name}" "${removable}" "${media_type}")"
        [ "${priority}" -lt 9 ] || continue

        candidates=$((candidates + 1))
        if [ "${priority}" -lt "${best_priority}" ]; then
            best_name="${name}"
            best_priority="${priority}"
            best_count=1
        elif [ "${priority}" -eq "${best_priority}" ]; then
            best_count=$((best_count + 1))
        fi
    done

    [ "${candidates}" -gt 0 ] || die "no valid target disk found"
    [ "${best_count}" -eq 1 ] ||
        die "multiple equally preferred target disks found; refusing to choose"

    printf '%s/%s\n' "${DEV_DIR}" "${best_name}"
}

confirm_target() {
    target="$1"
    if [ "${ASSUME_YES}" = "1" ]; then
        return 0
    fi
    [ -t 0 ] || die "confirmation requires a TTY; rerun with --yes only in factory automation"

    printf '\nTarget disk: %s\n' "${target}"
    printf 'This will overwrite the selected SD/eMMC. Continue? [y/N] '
    read -r answer
    [ "${answer}" = "y" ] || [ "${answer}" = "Y" ] || die "operator declined install"
}

target_size_bytes() {
    target="$1"
    name="$(basename "$(readlink -f "${target}" 2>/dev/null || printf '%s\n' "${target}")")"
    sectors="$(read_sys_value "${SYS_BLOCK}/${name}/size" "0")"
    printf '%s\n' "$((sectors * 512))"
}

partition_path() {
    disk="$1"
    number="$2"
    case "$(basename "${disk}")" in
        mmcblk*|nvme*n*)
            printf '%sp%s\n' "${disk}" "${number}"
            ;;
        *)
            printf '%s%s\n' "${disk}" "${number}"
            ;;
    esac
}

reread_partition_table() {
    target="$1"
    if command -v blockdev >/dev/null 2>&1; then
        blockdev --rereadpt "${target}" 2>/dev/null || true
    fi
    if command -v partprobe >/dev/null 2>&1; then
        partprobe "${target}" 2>/dev/null || true
    fi
    sync
    if command -v udevadm >/dev/null 2>&1; then
        udevadm settle 2>/dev/null || true
    fi
}

wait_for_partition() {
    partition="$1"
    tries=0
    while [ "${tries}" -lt 20 ]; do
        [ -b "${partition}" ] && return 0
        sleep 1
        tries=$((tries + 1))
    done
    die "partition did not appear: ${partition}"
}

verify_target_partitions() {
    target="$1"
    resolved="$(readlink -f "${target}" 2>/dev/null || printf '%s\n' "${target}")"
    boot_part="$(partition_path "${resolved}" 1)"
    root_part="$(partition_path "${resolved}" 2)"

    wait_for_partition "${boot_part}"
    wait_for_partition "${root_part}"

    boot_type="$(blkid -s TYPE -o value "${boot_part}" 2>/dev/null || true)"
    root_type="$(blkid -s TYPE -o value "${root_part}" 2>/dev/null || true)"
    case "${boot_type}" in
        vfat|fat) ;;
        *) die "boot partition type mismatch: ${boot_part} type=${boot_type}" ;;
    esac
    [ "${root_type}" = "ext4" ] ||
        die "root partition type mismatch: ${root_part} type=${root_type}"

    mount_dir="${REPORT_DIR}/target-boot"
    mkdir -p "${mount_dir}"
    mount "${boot_part}" "${mount_dir}"

    if [ -f "${mount_dir}/suderra-A.fit" ]; then
        # PROD signed-FIT image (ADR-0007): boot identity + kernel cmdline live
        # INSIDE the signed FIT (root=/dev/mapper/suderra-root behind dm-verity),
        # not in cmdline.txt. Mutating boot content would break the FIT/verity
        # integrity chain, so we VERIFY the signed-FIT boot chain and mutate
        # nothing. Slot identity is dm-verity/partlabel, not a post-flash PARTUUID.
        for f in suderra-A.fit suderra-B.fit u-boot.bin boot.scr; do
            if [ ! -f "${mount_dir}/${f}" ]; then
                umount "${mount_dir}" || true
                die "signed-FIT target boot partition missing ${f}"
            fi
        done
        if [ -f "${mount_dir}/cmdline.txt" ]; then
            umount "${mount_dir}" || true
            die "signed-FIT image must not carry a mutable cmdline.txt (bootargs are in the FIT)"
        fi
        log "==> signed-FIT boot chain verified; no post-flash cmdline mutation"
        sync
        umount "${mount_dir}"
    elif [ -f "${mount_dir}/cmdline.txt" ]; then
        # DEV image: kernel=Image + cmdline.txt; pin root to the flashed
        # partition's PARTUUID (stable across the removable installer media).
        root_partuuid="$(blkid -s PARTUUID -o value "${root_part}" 2>/dev/null || true)"
        [ -n "${root_partuuid}" ] || { umount "${mount_dir}" || true; die "root PARTUUID missing for ${root_part}"; }
        sed -i "s#root=[^ ]*#root=PARTUUID=${root_partuuid}#" "${mount_dir}/cmdline.txt"
        if ! grep -q "root=PARTUUID=${root_partuuid}" "${mount_dir}/cmdline.txt"; then
            umount "${mount_dir}" || true
            die "cmdline.txt PARTUUID update verification failed"
        fi
        sync
        umount "${mount_dir}"
    else
        umount "${mount_dir}" || true
        die "target boot partition has neither a signed FIT nor cmdline.txt"
    fi
}

install_image() {
    verify_payload
    target="$(select_target)"
    confirm_target "${target}"

    # shellcheck disable=SC1090
    . "${PLAN_FILE}"
    image_path="${SUDERRA_PAYLOAD_IMAGE_PATH}"
    uncompressed_sha="${SUDERRA_PAYLOAD_UNCOMPRESSED_SHA256}"
    uncompressed_size="${SUDERRA_PAYLOAD_UNCOMPRESSED_SIZE_BYTES}"
    min_storage="${SUDERRA_PAYLOAD_MIN_STORAGE_BYTES}"

    target_bytes="$(target_size_bytes "${target}")"
    [ "${target_bytes}" -ge "${min_storage}" ] ||
        die "target is smaller than required minimum: ${target_bytes} < ${min_storage}"

    if [ "${DRY_RUN}" = "1" ]; then
        log "==> Dry run: would write ${image_path} to ${target}"
        return 0
    fi

    [ -b "${target}" ] || die "target is not a block device: ${target}"

    log "==> Writing Suderra OS target image to ${target}"
    xz -dc "${image_path}" | dd of="${target}" bs=4M conv=fsync status=progress
    sync

    log "==> Re-reading partition table"
    reread_partition_table "${target}"

    log "==> Verifying written image prefix"
    actual="$(head -c "${uncompressed_size}" "${target}" | sha256sum | awk '{print $1}')"
    [ "${actual}" = "${uncompressed_sha}" ] ||
        die "written target verification failed"

    log "==> Verifying target partitions and boot identity"
    verify_target_partitions "${target}"

    mkdir -p "${REPORT_DIR}"
    {
        printf 'Suderra OS install complete\n'
        printf 'target=%s\n' "${target}"
        printf 'target_bytes=%s\n' "${target_bytes}"
        printf 'payload=%s\n' "${SUDERRA_PAYLOAD_IMAGE_NAME}"
        printf 'payload_sha256=%s\n' "${SUDERRA_PAYLOAD_COMPRESSED_SHA256}"
        printf 'uncompressed_sha256=%s\n' "${uncompressed_sha}"
        printf 'next=power off, remove USB installer, boot target media\n'
    } > "${REPORT_DIR}/provisioning-info.txt"

    log "==> Install complete"
    log "Remove the USB installer, then power the device back on."
    poweroff
}

COMMAND="--install"
while [ "$#" -gt 0 ]; do
    case "$1" in
        --install)
            COMMAND="--install"
            ;;
        --select-target)
            COMMAND="--select-target"
            ;;
        --verify-payload)
            COMMAND="--verify-payload"
            ;;
        --yes|-y)
            ASSUME_YES=1
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            usage >&2
            exit 2
            ;;
    esac
    shift
done

case "${COMMAND}" in
    --select-target)
        select_target
        ;;
    --verify-payload)
        verify_payload
        ;;
    --install)
        install_image
        ;;
esac
