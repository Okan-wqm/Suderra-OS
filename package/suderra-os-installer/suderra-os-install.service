[Unit]
Description=Suderra OS USB self-installer
Documentation=https://github.com/Okan-wqm/suderra-os
DefaultDependencies=no
After=local-fs.target systemd-udev-settle.service
Wants=systemd-udev-settle.service
Conflicts=shutdown.target

[Service]
Type=oneshot
ExecStart=/usr/sbin/suderra-os-install --install
StandardInput=tty-force
StandardOutput=tty
StandardError=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes

[Install]
WantedBy=multi-user.target
