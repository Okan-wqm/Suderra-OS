[Unit]
Description=Mark current Suderra OS RAUC slot good
Documentation=https://rauc.readthedocs.io/
After=multi-user.target boot.mount suderra-data.service rauc.service
Wants=boot.mount suderra-data.service
ConditionPathExists=/etc/rauc/system.conf
ConditionKernelCommandLine=|rauc.slot=A
ConditionKernelCommandLine=|rauc.slot=B

[Service]
Type=oneshot
ExecStart=/usr/sbin/suderra-rauc-mark-good
RemainAfterExit=yes
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/data /boot

[Install]
WantedBy=multi-user.target
