#!/bin/sh
set -eu

if [ ! -x /usr/bin/rauc ]; then
    echo "ERROR: rauc binary missing" >&2
    exit 1
fi
if [ ! -x /usr/sbin/suderra-rauc-boot-state ]; then
    echo "ERROR: suderra-rauc-boot-state missing" >&2
    exit 1
fi
if [ ! -x /usr/sbin/suderra-rauc-health-gate ]; then
    echo "ERROR: suderra-rauc-health-gate missing" >&2
    exit 1
fi

mkdir -p /data/rauc
if ! /usr/sbin/suderra-rauc-health-gate; then
    /usr/sbin/suderra-rauc-boot-state >/data/rauc/health-rollback-pre.json || true
    if [ -x /usr/bin/suderra-ota ]; then
        /usr/bin/suderra-ota rollback --reason health-gate
    else
        /usr/bin/rauc status mark-bad
        /sbin/reboot "suderra-rauc health-gate" || true
    fi
    exit 1
fi
/usr/sbin/suderra-rauc-boot-state >/data/rauc/pre-mark-good.json
if [ -x /usr/bin/suderra-ota ]; then
    if ! /usr/bin/suderra-ota mark-good; then
        /usr/bin/suderra-ota rollback --reason mark-good-failed || true
        exit 1
    fi
elif ! /usr/bin/rauc status mark-good; then
    /usr/bin/rauc status mark-bad || true
    exit 1
fi
/usr/sbin/suderra-rauc-boot-state >/data/rauc/mark-good.json
