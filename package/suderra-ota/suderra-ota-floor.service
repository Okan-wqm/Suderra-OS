#
# RT-6: TPM-NV-çıpalı anti-rollback floor'unu boot'ta runtime yoluna senkronize
# eder. Downgrade (imaj epoch'u < donanım counter'ı) fail-closed: floor yazılmaz,
# güncelleme yolu #84 invariantıyla kilitlenir. mark-good'dan ÖNCE çalışır.
# Yalnız /etc/suderra/ota.conf tpm-nv beyan ettiğinde anlamlı (aksi halde no-op).

[Unit]
Description=Suderra OTA rollback floor sync (TPM-NV anchor)
Documentation=https://github.com/Okan-wqm/Suderra-OS
After=suderra-data.service
Before=suderra-ota-mark-good.service
ConditionPathExists=/etc/suderra/ota.conf

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/suderra-ota floor sync
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/suderra
DevicePolicy=closed
DeviceAllow=/dev/tpmrm0 rw
DeviceAllow=/dev/tpm0 rw

[Install]
WantedBy=multi-user.target
