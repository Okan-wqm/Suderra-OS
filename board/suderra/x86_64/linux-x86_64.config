#
# Suderra OS — x86_64 kernel config (Katman 3)
#
# Bu config QEMU virtio + gerçek endüstriyel x86 PC'lerin yaygın donanım
# desteğini içerir. Faz 3'te kernel-fragment.config ile sertleştirilir.
#
# Üretim:
#   make ARCH=x86_64 -C buildroot/output/.../build/linux-* savedefconfig
#   cp buildroot/output/.../build/linux-*/defconfig board/suderra/x86_64/linux-x86_64.config
#
# Hedef boyut: ~6-8 MB compressed (vs Ubuntu generic ~50 MB)
#

# 64-bit
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=8

# Compiler hardening (ileri kernel'lerde varsayılan)
CONFIG_CC_HAS_AUTO_VAR_INIT_PATTERN=y
CONFIG_INIT_STACK_ALL_ZERO=y
CONFIG_GCC_PLUGIN_STACKLEAK=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_PAGE_TABLE_ISOLATION=y
CONFIG_RETPOLINE=y
CONFIG_X86_SMAP=y
CONFIG_X86_UMIP=y

# CPU features
CONFIG_GENERIC_CPU=y
CONFIG_X86_PAT=y
CONFIG_X86_MCE=y

# Memory
CONFIG_SLUB=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_HZ_1000=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ_IDLE=y

# Block / Storage
CONFIG_BLOCK=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_RAM=y
CONFIG_BLK_DEV_NVME=y          # NVMe (modern endüstriyel)
CONFIG_ATA=y
CONFIG_SATA_AHCI=y             # SATA (legacy)
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_VFAT_FS=y               # EFI partition
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Faz 3 için hazır (henüz aktif değil):
# CONFIG_DM_VERITY=y
# CONFIG_BLK_DEV_DM=y
# CONFIG_EROFS_FS=y

# Networking — TCP/IP only, IPv6 minimum
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_NETLINK=y
CONFIG_NF_TABLES=y             # nftables (Faz 3'te aktif konfig)
CONFIG_IPV6=y                  # systemd istiyor, ama nftables ile kapatabiliriz
CONFIG_INET_DIAG=y

# Network drivers — virtio (QEMU) + Intel/Realtek (gerçek hw)
CONFIG_NETDEVICES=y
CONFIG_VIRTIO_NET=y            # QEMU
CONFIG_E1000=y                 # Intel legacy (Pro/1000)
CONFIG_E1000E=y                # Intel modern (I217/I219)
CONFIG_IGB=y                   # Intel I210/I211 (endüstriyel)
CONFIG_IGC=y                   # Intel I225/I226 (TSN/PTP destekli)
CONFIG_R8169=y                 # Realtek

# Virtio (QEMU)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y

# UEFI
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=y
CONFIG_EFI_VARS=y

# Watchdog (donanım dondu reboot)
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_CORE=y
CONFIG_ITCO_WDT=y              # Intel iTCO (yaygın endüstriyel)
CONFIG_SOFT_WATCHDOG=y         # fallback

# TPM 2.0
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_CRB=y
CONFIG_TCG_VTPM_PROXY=y        # QEMU swtpm

# RTC (real-time clock)
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_CMOS=y

# Console
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y

# Cryptography (rustls + LUKS2 için)
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_AES_NI_INTEL=y   # AES-NI hardware acceleration
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_HMAC=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_XTS=y            # LUKS2

# Power management
CONFIG_PM=y
CONFIG_ACPI=y
CONFIG_ACPI_AC=y
CONFIG_ACPI_BATTERY=y
CONFIG_ACPI_BUTTON=y
CONFIG_ACPI_FAN=y
CONFIG_ACPI_THERMAL=y
CONFIG_HWMON=y
CONFIG_SENSORS_CORETEMP=y      # CPU sıcaklık (telemetry için)

# Random
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_TPM=y
CONFIG_HW_RANDOM_VIRTIO=y      # QEMU virtio-rng

# Cgroup v2 (systemd zorunlu)
CONFIG_CGROUPS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_SCHED=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y

# Namespaces
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y               # Faz 3'te kapatılabilir (saldırı yüzeyi)

# seccomp + audit (Faz 3 + sertleştirme)
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y

# memfd_secret (Edge Agent zorunlu)
CONFIG_MEMFD_CREATE=y
CONFIG_SECRETMEM=y

# systemd zorunlu özellikler
CONFIG_FHANDLE=y
CONFIG_INOTIFY_USER=y
CONFIG_AUTOFS4_FS=y

# Disable unused (saldırı yüzeyi azalt)
# CONFIG_BT is not set
# CONFIG_BLUETOOTH is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_NFC is not set
# CONFIG_RDS is not set
# CONFIG_DCCP is not set
# CONFIG_SCTP is not set
# CONFIG_TIPC is not set
# CONFIG_ATM is not set
# CONFIG_X25 is not set
# CONFIG_DECNET is not set
# CONFIG_LLC2 is not set
# CONFIG_USERFAULTFD is not set

# Module loading — Faz 3'te kapatılır (monolithic)
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
# Faz 3: # CONFIG_MODULES is not set
