#
# Suderra OS — Kernel hardening fragment
#
# Bu fragment tüm mimarilerde uygulanan ORTAK sertleştirme ayarlarıdır.
# Mimari-spesifik ayarlar board/suderra/<arch>/linux-*.config içinde.
#
# Buildroot kullanımı:
#   BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_SUDERRA_PATH)/board/suderra/common/kernel-fragment.config"
#
# Detaylı gerekçe: docs/security/kernel-hardening.md
#

# === Lockdown ===
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y

# === Integrity / dm-verity ===
CONFIG_INTEGRITY=y
CONFIG_INTEGRITY_SIGNATURE=y
CONFIG_INTEGRITY_TRUSTED_KEYRING=y
CONFIG_SECONDARY_TRUSTED_KEYRING=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_FEC=y

# === TPM 2.0 ===
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_CRB=y
CONFIG_TRUSTED_KEYS=y
CONFIG_TRUSTED_KEYS_TPM=y

# === Memory protection ===
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_VMAP_STACK=y
CONFIG_THREAD_INFO_IN_TASK=y
CONFIG_PAGE_POISONING=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_HARDENED_USERCOPY=y
# CONFIG_HARDENED_USERCOPY_FALLBACK is not set

# === Attack surface azaltma ===
# CONFIG_MODULES is not set
# CONFIG_KEXEC is not set
# CONFIG_KEXEC_FILE is not set
# CONFIG_HIBERNATION is not set
# CONFIG_USER_NS is not set
# CONFIG_LEGACY_VSYSCALL_NONE not used; use CONFIG_LEGACY_VSYSCALL_NONE=y if x86
# CONFIG_X86_VSYSCALL_EMULATION is not set
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# === Syscall ve LSM ===
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY=y
CONFIG_SECURITY_YAMA=y
CONFIG_LSM="yama,bpf,landlock"

# === Bilgi sızıntısı koruması ===
CONFIG_RANDOMIZE_KSTACK_OFFSET=y
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y

# === Network ===
# IPv6 derlenir ama runtime'da sysctl ile kapanır (esneklik için)
CONFIG_IPV6=y

# === Cryptography ===
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y

# === Audit ===
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y
