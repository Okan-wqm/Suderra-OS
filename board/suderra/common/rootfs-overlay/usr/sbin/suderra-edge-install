#!/bin/sh
set -eu

CONFIG=/etc/suderra/edge-install.env
STATE_DIR=/var/lib/suderra/edge
CONFIG_DIR=/var/lib/suderra/config
WORK_DIR="${STATE_DIR}/install"
RELEASES_DIR=/opt/suderra/edge/releases
CURRENT_LINK=/opt/suderra/edge/current
EDGE_PUBKEY="${SUDERRA_EDGE_PUBKEY:-/etc/suderra/edge-artifact.ed25519.pub}"
VERIFY_BIN="${SUDERRA_INSTALLER_VERIFY_BIN:-/usr/bin/suderra-installer}"

VERSION=
URL=
EXPECTED_SHA256=
BIN_NAME=suderra-agent
FORMAT=tar.gz
LOCKDOWN_AFTER_INSTALL=1
INTERACTIVE=0
MANIFEST=
MANIFEST_URL=
MIN_KEY_EPOCH="${SUDERRA_EDGE_MIN_KEY_EPOCH:-1}"
MIN_ROLLBACK_FLOOR="${SUDERRA_EDGE_MIN_ROLLBACK_FLOOR:-v0.1.0-alpha}"

usage() {
    cat <<'EOF'
Usage:
  suderra-edge-install --manifest FILE
  suderra-edge-install --manifest-url URL
  suderra-edge-install --interactive

Suderra OS manifests must include:
  version, artifact_url, sha256, signature_url, binary_name

Optional fields:
  config.payload
EOF
}

detect_board() {
    if [ -n "${SUDERRA_TARGET_BOARD:-}" ]; then
        printf '%s\n' "${SUDERRA_TARGET_BOARD}"
        return 0
    fi
    if [ -r /proc/device-tree/model ]; then
        model="$(tr -d '\000' < /proc/device-tree/model)"
        case "${model}" in
            *RevPi*|*Revolution\ Pi*) printf '%s\n' "revpi4"; return 0 ;;
            *Raspberry\ Pi*|*Compute\ Module*) printf '%s\n' "rpi4-cm4"; return 0 ;;
        esac
    fi
    echo "ERROR: unable to detect target board; set SUDERRA_TARGET_BOARD" >&2
    exit 2
}

detect_arch() {
    case "$(uname -m)" in
        aarch64|arm64) printf '%s\n' "aarch64" ;;
        x86_64|amd64) printf '%s\n' "x86_64" ;;
        *) uname -m ;;
    esac
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --interactive)
            INTERACTIVE=1
            ;;
        --manifest)
            MANIFEST="${2:-}"
            shift
            ;;
        --manifest-url)
            MANIFEST_URL="${2:-}"
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            usage >&2
            exit 2
            ;;
    esac
    shift
done

if [ -f "${CONFIG}" ]; then
    # shellcheck disable=SC1090
    . "${CONFIG}"
    URL="${SUDERRA_EDGE_URL:-${URL}}"
    EXPECTED_SHA256="${SUDERRA_EDGE_SHA256:-${EXPECTED_SHA256}}"
    VERSION="${SUDERRA_EDGE_VERSION:-${VERSION}}"
    FORMAT="${SUDERRA_EDGE_ARTIFACT_FORMAT:-${FORMAT}}"
    BIN_NAME="${SUDERRA_EDGE_BINARY_NAME:-${BIN_NAME}}"
    LOCKDOWN_AFTER_INSTALL="${SUDERRA_LOCKDOWN_AFTER_INSTALL:-${LOCKDOWN_AFTER_INSTALL}}"
    MIN_KEY_EPOCH="${SUDERRA_EDGE_MIN_KEY_EPOCH:-${MIN_KEY_EPOCH}}"
    MIN_ROLLBACK_FLOOR="${SUDERRA_EDGE_MIN_ROLLBACK_FLOOR:-${MIN_ROLLBACK_FLOOR}}"
fi

mkdir -p "${WORK_DIR}" "${CONFIG_DIR}" "${RELEASES_DIR}" /var/log/suderra
chmod 0750 /var/lib/suderra "${STATE_DIR}" "${WORK_DIR}" "${CONFIG_DIR}" /var/log/suderra 2>/dev/null || true
chown root:root /var/lib/suderra 2>/dev/null || true
chown suderra:suderra "${STATE_DIR}" "${WORK_DIR}" "${CONFIG_DIR}" /var/log/suderra 2>/dev/null || true

if [ -n "${MANIFEST_URL}" ]; then
    MANIFEST="${WORK_DIR}/edge-manifest.json"
    echo "==> Downloading Suderra OS Edge manifest"
    curl --fail --location --show-error --silent --output "${MANIFEST}" "${MANIFEST_URL}"
fi

if [ -n "${MANIFEST}" ]; then
    [ -f "${MANIFEST}" ] || {
        echo "ERROR: manifest not found: ${MANIFEST}" >&2
        exit 2
    }
    [ -x "${VERIFY_BIN}" ] || {
        echo "ERROR: suderra-installer verifier missing: ${VERIFY_BIN}" >&2
        exit 2
    }
    [ -s "${EDGE_PUBKEY}" ] || {
        echo "ERROR: pinned Edge artifact public key missing: ${EDGE_PUBKEY}" >&2
        exit 2
    }
    PLAN_FILE="${WORK_DIR}/edge-plan.env"
    CONFIG_PAYLOAD_FILE="${WORK_DIR}/config-payload.yaml"
    TARGET_BOARD="$(detect_board)"
    TARGET_ARCH="$(detect_arch)"
    "${VERIFY_BIN}" edge-manifest plan \
        --manifest "${MANIFEST}" \
        --public-key "${EDGE_PUBKEY}" \
        --board "${TARGET_BOARD}" \
        --arch "${TARGET_ARCH}" \
        --min-key-epoch "${MIN_KEY_EPOCH}" \
        --min-rollback-floor "${MIN_ROLLBACK_FLOOR}" \
        --write-plan "${PLAN_FILE}" \
        --config-output "${CONFIG_PAYLOAD_FILE}"
    # shellcheck disable=SC1090
    . "${PLAN_FILE}"
    VERSION="${SUDERRA_EDGE_VERSION}"
    URL="${SUDERRA_EDGE_ARTIFACT_URL}"
    EXPECTED_SHA256="${SUDERRA_EDGE_SHA256}"
    BIN_NAME="${SUDERRA_EDGE_BINARY_NAME}"
    FORMAT="${SUDERRA_EDGE_ARTIFACT_FORMAT}"
else
    CONFIG_PAYLOAD_FILE=
fi

if [ "${INTERACTIVE}" = "1" ] && [ -z "${URL}" ]; then
    printf "Edge artifact URL: "
    read -r URL
fi

if [ "${INTERACTIVE}" = "1" ] && [ -z "${EXPECTED_SHA256}" ]; then
    printf "Edge artifact SHA256: "
    read -r EXPECTED_SHA256
fi

if [ -z "${MANIFEST}" ]; then
    echo "ERROR: signed provisioning manifest is required." >&2
    exit 2
fi

if [ -z "${VERSION}" ] || [ -z "${URL}" ] || [ -z "${EXPECTED_SHA256}" ]; then
    echo "ERROR: verified manifest did not produce version, artifact URL and SHA256." >&2
    exit 2
fi

ARTIFACT="${WORK_DIR}/edge-artifact"
EXTRACT_DIR="${WORK_DIR}/extract"
RELEASE_DIR="${RELEASES_DIR}/${VERSION}"

rm -rf "${EXTRACT_DIR}"
mkdir -p "${EXTRACT_DIR}" "${RELEASE_DIR}"

echo "==> Downloading Suderra Edge artifact"
curl --fail --location --show-error --silent --output "${ARTIFACT}" "${URL}"

echo "==> Verifying signed Suderra Edge artifact"
"${VERIFY_BIN}" edge-manifest verify-artifact \
    --manifest "${MANIFEST}" \
    --public-key "${EDGE_PUBKEY}" \
    --artifact "${ARTIFACT}" \
    --board "${TARGET_BOARD}" \
    --arch "${TARGET_ARCH}" \
    --min-key-epoch "${MIN_KEY_EPOCH}" \
    --min-rollback-floor "${MIN_ROLLBACK_FLOOR}"

case "${FORMAT}" in
    tar.gz|tgz)
        tar -xzf "${ARTIFACT}" -C "${EXTRACT_DIR}"
        CANDIDATE="$(find "${EXTRACT_DIR}" -type f -name "${BIN_NAME}" | head -n 1)"
        ;;
    raw|bin)
        CANDIDATE="${ARTIFACT}"
        ;;
    *)
        echo "ERROR: unsupported artifact_format=${FORMAT}" >&2
        exit 2
        ;;
esac

if [ -z "${CANDIDATE:-}" ] || [ ! -f "${CANDIDATE}" ]; then
    echo "ERROR: ${BIN_NAME} not found in artifact" >&2
    exit 2
fi

echo "==> Installing ${BIN_NAME} to ${RELEASE_DIR}"
install -m 0755 "${CANDIDATE}" "${RELEASE_DIR}/.suderra-agent.new"
chown root:root "${RELEASE_DIR}/.suderra-agent.new"
mv -f "${RELEASE_DIR}/.suderra-agent.new" "${RELEASE_DIR}/suderra-agent"
ln -sfn "releases/${VERSION}" "${CURRENT_LINK}"
chown -h root:root "${CURRENT_LINK}" 2>/dev/null || true

if [ -n "${CONFIG_PAYLOAD_FILE:-}" ] && [ -s "${CONFIG_PAYLOAD_FILE}" ]; then
    install -m 0600 "${CONFIG_PAYLOAD_FILE}" "${CONFIG_DIR}/config.yaml"
elif [ ! -f "${CONFIG_DIR}/config.yaml" ]; then
    {
        printf 'device_id: "00000000-0000-0000-0000-000000000000"\n'
        printf 'device_code: "UNACTIVATED"\n'
        printf 'api_url: "https://provisioning.example.com"\n'
        if [ -n "${ACTIVATION_TOKEN:-}" ]; then
            printf 'provisioning_token: "%s"\n' "${ACTIVATION_TOKEN}"
        fi
        printf 'mqtt:\n'
        printf '  broker: null\n'
        printf '  port: 8883\n'
        printf '  username: null\n'
        printf '  password: null\n'
        printf '  tls:\n'
        printf '    enabled: true\n'
        printf '    verify_hostname: true\n'
        printf '  topics: {}\n'
    } > "${CONFIG_DIR}/config.yaml"
fi
chown suderra:suderra "${CONFIG_DIR}/config.yaml" 2>/dev/null || true
chmod 0600 "${CONFIG_DIR}/config.yaml"

echo "==> Enabling Suderra Edge service"
systemctl daemon-reload
systemctl enable suderra-agent.service
systemctl restart suderra-agent.service

if [ "${LOCKDOWN_AFTER_INSTALL}" = "1" ]; then
    /usr/sbin/suderra-lockdown
else
    echo "==> Lockdown skipped by SUDERRA_LOCKDOWN_AFTER_INSTALL=${LOCKDOWN_AFTER_INSTALL}"
fi

echo "==> Suderra Edge install complete"
