#!/bin/sh
set -eu

BASE_DIR=/var/spool/suderra-provision
REQUEST_DIR="${BASE_DIR}/inbox"
RESULT_FILE="${BASE_DIR}/result"
TRANSACTION_DIR="${BASE_DIR}/transaction"

umask 077
mkdir -p "${REQUEST_DIR}"

write_result() {
    status="$1"
    message="$2"
    {
        printf 'status=%s\n' "${status}"
        printf 'message=%s\n' "${message}"
    } > "${RESULT_FILE}.tmp"
    chown provision:provision "${RESULT_FILE}.tmp" 2>/dev/null || true
    mv -f "${RESULT_FILE}.tmp" "${RESULT_FILE}"
}

if [ -f /var/lib/suderra/.appliance-locked ]; then
    write_result error "device is locked"
    exit 1
fi

rm -rf "${TRANSACTION_DIR}"
mkdir -p "${TRANSACTION_DIR}"
chown root:root "${TRANSACTION_DIR}" 2>/dev/null || true
chmod 0700 "${TRANSACTION_DIR}"

# inbox provision kullanıcısına ait (0700, uid 201): dosyayı önce root'a ait
# transaction dizinine mv ile taşı (rename symlink'i DEREF ETMEZ ve atomiktir),
# tür kontrolünü taşınmış kopya üzerinde yap. Bu sıra, kontrol-sonrası-değiştir
# (TOCTOU) yarışını ve root'un saldırgan symlink/fifo'sunu okumasını engeller.
claim_request() {
    name="$1"
    [ -e "${REQUEST_DIR}/${name}" ] || [ -h "${REQUEST_DIR}/${name}" ] || return 1
    mv -f "${REQUEST_DIR}/${name}" "${TRANSACTION_DIR}/${name}" 2>/dev/null || return 1
    if [ -h "${TRANSACTION_DIR}/${name}" ] || [ ! -f "${TRANSACTION_DIR}/${name}" ] \
        || [ ! -s "${TRANSACTION_DIR}/${name}" ]; then
        return 1
    fi
    return 0
}

if claim_request manifest-url; then
    rm -f "${REQUEST_DIR}/manifest-url" "${REQUEST_DIR}/manifest.json" "${REQUEST_DIR}/trigger"
    manifest_url="$(head -n 1 "${TRANSACTION_DIR}/manifest-url")"
    if /usr/sbin/suderra-edge-install --manifest-url "${manifest_url}"; then
        write_result ok "edge install completed"
        rm -rf "${TRANSACTION_DIR}"
    else
        write_result error "edge install failed"
    fi
elif claim_request manifest.json; then
    rm -f "${REQUEST_DIR}/manifest-url" "${REQUEST_DIR}/manifest.json" "${REQUEST_DIR}/trigger"
    if /usr/sbin/suderra-edge-install --manifest "${TRANSACTION_DIR}/manifest.json"; then
        write_result ok "edge install completed"
        rm -rf "${TRANSACTION_DIR}"
    else
        write_result error "edge install failed"
    fi
else
    write_result error "no provisioning request found"
fi
