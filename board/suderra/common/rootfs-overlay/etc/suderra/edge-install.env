# Suderra Edge runtime install configuration.
#
# Factory/provisioning flow:
# 1. Boot Suderra OS.
# 2. Tenant panel connects as the temporary provision user.
# 3. /usr/sbin/suderra-provision accepts a Suderra OS manifest URL/JSON.
# 4. The root worker downloads, verifies, installs, starts suderra-agent, then
#    locks the OS only after registration is confirmed.
#
# Direct values are kept for lab use; production uses --manifest-url/--manifest.
SUDERRA_EDGE_VERSION=""
SUDERRA_EDGE_URL=""
SUDERRA_EDGE_SHA256=""
SUDERRA_EDGE_SIGNATURE_URL=""
SUDERRA_EDGE_ARTIFACT_FORMAT="tar.gz"
SUDERRA_EDGE_BINARY_NAME="suderra-agent"
SUDERRA_LOCKDOWN_AFTER_INSTALL="1"
