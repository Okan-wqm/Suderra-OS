[Unit]
Description=Suderra OS provisioning worker
Documentation=https://github.com/Okan-wqm/suderra-os
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/sbin/suderra-provision-worker
User=root
Group=root
UMask=0077
NoNewPrivileges=false
PrivateTmp=true
ProtectHome=true
ReadWritePaths=/var/lib/suderra /var/log/suderra /opt/suderra /etc/suderra /etc/systemd/system /etc/shadow
