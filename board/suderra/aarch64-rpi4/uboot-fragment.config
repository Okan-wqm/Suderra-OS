#
# Suderra OS — U-Boot config fragment (Pi 4 / CM4 / RevPi Connect 4)
#
# rpi_arm64_defconfig üzerine uygulanır. Amaç: U-Boot'u imzalı FIT için güven
# kökü yapmak (ADR-0007). Bu aşamada (PR-A2) yalnız DERLENİR; config.txt hâlâ
# kerneli doğrudan yükler (PR-A4 chainload'a çevirir).
#
# FIT doğrulama açık anahtarı, imzalama sırasında `mkimage -K u-boot.dtb` ile
# U-Boot kontrol DTB'sine gömülür (PR-A3). CONFIG_FIT_SIGNATURE, U-Boot'un
# bootm sırasında bu anahtarla FIT imzasını zorunlu doğrulamasını sağlar.
#

# === Flattened Image Tree + imza doğrulama ===
CONFIG_FIT=y
CONFIG_FIT_SIGNATURE=y
CONFIG_RSA=y
CONFIG_SHA256=y
# Çok-kartlı FIT config seçimi (HIGH1): `bootm ${fitaddr}` (#conf'suz) yalnız
# FIT_BEST_MATCH açıkken çalışan-kartın compatible'ıyla doğru config'i seçer;
# OLMADAN default config (alfabetik ilk = Pi 4B) boot edilir → CM4/CM4-IO yanlış
# DTB alır. Bu satır olmadan multi-board üretici boot'ta ETKİSİZDİR.
CONFIG_FIT_BEST_MATCH=y

# === Kontrol FDT (mkimage -K pubkey'i buraya gömer) ===
CONFIG_OF_CONTROL=y

# === Boot script + ortam ===
# RAUC U-Boot backend'i (PR-A5) fw_setenv ile BOOT_ORDER/BOOT_x_LEFT yazar;
# bu yüzden ortam ENV_IS_NOWHERE ile kilitlenMEZ. Boot script FAT'ten okunur.
CONFIG_CMD_BOOTEFI=y
CONFIG_CMD_FDT=y
CONFIG_CMD_PART=y

# === Ortam deposu FAT'te AÇIKÇA sabitlenir (corr-L3) ===
# fw_env.config /boot/uboot.env (0x4000) kullanır. RAUC fw_setenv, boot.scr
# saveenv ve BOOT_x_LEFT azaltma AYNI depoya yazmalı; yoksa A/B rollback
# sessizce no-op olur. rpi_arm64 varsayılanı ENV_IS_IN_FAT olsa da açıkça
# sabitleyip upstream defconfig drift'ine karşı korunuyoruz. (Donanımda G4 ile
# fw_printenv/boot arası tutarlılık doğrulanır.)
CONFIG_ENV_IS_IN_FAT=y
CONFIG_ENV_FAT_INTERFACE="mmc"
CONFIG_ENV_FAT_DEVICE_AND_PART="0:1"
CONFIG_ENV_FAT_FILE="uboot.env"
CONFIG_ENV_SIZE=0x4000

# === UEFI capsule güncellemesini kapat ===
# rpi_arm64_defconfig EFI capsule-on-disk'i açıyor; host aracı mkeficapsule
# gnutls başlıkları ister (CI/build host'unda yok) ve build'i kırar. Suderra
# ARM güncellemesi imzalı FIT + RAUC A/B kullanır, UEFI capsule DEĞİL — bu
# yüzden özelliği ve host aracını kapatıyoruz (daha az saldırı yüzeyi + gnutls
# host bağımlılığı yok).
# CONFIG_EFI_CAPSULE_ON_DISK is not set
# CONFIG_EFI_CAPSULE_FIRMWARE_FIT is not set
# CONFIG_EFI_CAPSULE_FIRMWARE_RAW is not set
# CONFIG_EFI_CAPSULE_AUTHENTICATE is not set
# CONFIG_TOOLS_MKEFICAPSULE is not set
