#
# Suderra OS — arm64 kernel hardening fragment (Pi 4 / CM4 / RevPi Connect 4)
#
# board/suderra/common/kernel-fragment.config x86 prod imajlarına uygulanan
# ortak sertleştirmenin, BCM2711 üzerinde BOOT-GÜVENLİ olduğu doğrulanabilen
# alt kümesidir + arm64'e özgü eklemeler. linux-rpi4.config'den SONRA
# uygulanır (merge_config: son fragment kazanır).
#
# Bilinçli olarak ERTELENENLER (donanım lab kanıtı olmadan uygulanmaz —
# bkz. docs/security/kernel-hardening.md ve build-matrix blocker alanları):
#   - "# CONFIG_MODULES is not set"  → bcm2711 sürücü seti modüllere bağımlı;
#     monolitik kernel ancak donanımda boot kanıtıyla gelir.
#   - CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY → Pi firmware boot
#     zincirinde imzalı kernel zorlaması yokken firmware arayüzlerini
#     (mailbox/vcgencmd) kırma riski taşır; signed-FIT fazına gate'li.
#

# === Lockdown LSM (derli ama zorlamasız; cmdline/sysfs ile aktive edilebilir) ===
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y

# === LSM sırası (x86 ortak fragment ile hizalı + lockdown başta) ===
CONFIG_SECURITY=y
CONFIG_SECURITY_YAMA=y
# Landlock derli: politika yüklenmeden pasif, boot-riski yok; edge-agent'ın
# gelecekte kendi kendini kısıtlaması için hazır. Listedeki "bpf" girdisi
# BPF_LSM derlenmediği sürece kernel tarafından atlanır (bilinçli: LSM-bpf
# tek iş yükü cihazında kullanılmıyor, yüzey eklemiyoruz).
CONFIG_SECURITY_LANDLOCK=y
CONFIG_LSM="lockdown,yama,bpf,landlock"

# === Memory protection (x86 ortak fragment paritesi) ===
CONFIG_VMAP_STACK=y
CONFIG_THREAD_INFO_IN_TASK=y
CONFIG_PAGE_POISONING=y
CONFIG_RANDOMIZE_KSTACK_OFFSET=y
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y

# === arm64'e özgü ===
# Cortex-A72 (ARMv8.0) donanım PAN taşımaz; software emülasyonu aç
CONFIG_ARM64_SW_TTBR0_PAN=y
# rodata=full default (linear alias'lar dahil W^X)
CONFIG_RODATA_FULL_DEFAULT_ENABLED=y
# KPTI eşleniği (arm64 default'u zaten y; açıkça sabitle)
CONFIG_UNMAP_KERNEL_AT_EL0=y
CONFIG_STRICT_DEVMEM=y

# === Attack surface azaltma (boot-güvenli alt küme) ===
# CONFIG_KEXEC is not set
# CONFIG_KEXEC_FILE is not set
# CONFIG_HIBERNATION is not set
# Edge Agent user namespace kullanmıyor (x86 prod ile hizalı; hiçbir
# systemd unit PrivateUsers kullanmıyor — arm-hardening contract testi korur)
# CONFIG_USER_NS is not set
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y

# === TPM 2.0 (RevPi Connect 4: SLB9670-serisi SPI TPM; Pi 4'te aygıt yoksa zararsız) ===
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS_CORE=y
CONFIG_TCG_TIS_SPI=y

# === dm-verity zemin hazırlığı (DM_VERITY/DM_CRYPT zaten linux-rpi4.config'de) ===
CONFIG_DM_INIT=y
CONFIG_DM_VERITY_FEC=y
