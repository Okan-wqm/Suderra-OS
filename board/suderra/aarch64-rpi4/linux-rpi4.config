#
# Suderra OS — Linux kernel config fragment (Raspberry Pi 4 / CM4)
#
# Bu dosya Buildroot tarafından kernel 'make defconfig' sonrası override
# olarak uygulanır. BCM2711 SoC, Pi 4 / CM4 board, endüstriyel I/O ve
# systemd gereksinimlerinin minimum tam çalışan kombinasyonudur.
#
# Inheritance: defconfig (bcm2711_defconfig) + bu fragment
#

# ============================================================================
# Architecture
# ============================================================================
CONFIG_ARM64=y
CONFIG_ARCH_BCM=y
CONFIG_ARCH_BCM2835=y
CONFIG_ARM_PSCI=y

# Cortex-A72 (BCM2711 = 4x Cortex-A72)
CONFIG_ARM64_VA_BITS_39=y
CONFIG_ARM64_4K_PAGES=y
CONFIG_HZ_250=y

# ============================================================================
# SoC firmware mailbox & power
# ============================================================================
CONFIG_RASPBERRYPI_FIRMWARE=y
CONFIG_RASPBERRYPI_POWER=y
CONFIG_BCM2835_MBOX=y

# ============================================================================
# Storage — SD card (mmcblk0)
# ============================================================================
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_IPROC=y
CONFIG_MMC_BCM2835=y
CONFIG_MMC_BCM2835_MMC=y

# eMMC (CM4 onboard eMMC variants)
CONFIG_MMC_SDHCI_OF_ARASAN=y

# ============================================================================
# USB — Pi 4 has 2x USB3 + 2x USB2 via VL805 PCIe controller
# ============================================================================
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_COMMON=y
CONFIG_USB_DWC2=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_STORAGE=y
CONFIG_USB_HID=y

# PCI Express (Pi 4 native PCIe)
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_PCIE_BRCMSTB=y

# ============================================================================
# Network — Pi 4 onboard ethernet (BCM54213PE via genet)
# ============================================================================
CONFIG_BCMGENET=y
CONFIG_BROADCOM_PHY=y
CONFIG_BCM_NET_PHYLIB=y
CONFIG_MDIO_BCM_UNIMAC=y

# Network stack
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETLINK_DIAG=y

# Wireless (CM4'te BCM43455 — opsiyonel kapalı)
# CONFIG_BRCMFMAC=m

# ============================================================================
# Filesystems
# ============================================================================
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_UTF8=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_ASCII=y
CONFIG_NLS_UTF8=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XATTR=y

# erofs (Faz 3'te dm-verity ile kullanılır)
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_XATTR=y

# Overlay (firstboot için /data overlay)
CONFIG_OVERLAY_FS=y

# Device mapper (Faz 3 dm-verity)
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_CRYPT=y

# ============================================================================
# Endüstriyel I/O — GPIO, I2C, SPI, PWM, 1-Wire
# ============================================================================

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_BCM_VIRT=y
CONFIG_GPIO_RASPBERRYPI_EXP=y
CONFIG_GPIO_SYSFS=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_BCM2835=y

# I2C
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_BCM2835=y
CONFIG_I2C_GPIO=y

# SPI
CONFIG_SPI=y
CONFIG_SPI_BCM2835=y
CONFIG_SPI_BCM2835AUX=y
CONFIG_SPIDEV=y

# PWM
CONFIG_PWM=y
CONFIG_PWM_BCM2835=y

# 1-Wire (DS18B20 sıcaklık sensörü için)
CONFIG_W1=y
CONFIG_W1_MASTER_GPIO=y
CONFIG_W1_SLAVE_THERM=y

# ============================================================================
# Hardware watchdog (BCM2835)
# ============================================================================
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_CORE=y
CONFIG_BCM2835_WDT=y

# ============================================================================
# Serial console (PL011 UART)
# ============================================================================
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_BCM2835AUX=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_SERIAL_DEV_BUS=y

# ============================================================================
# Random / crypto (Edge Agent için kritik)
# ============================================================================
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_BCM2835=y
CONFIG_HW_RANDOM_IPROC_RNG200=y
CONFIG_CRYPTO=y
CONFIG_CRYPTO_USER_API=y
CONFIG_CRYPTO_USER_API_HASH=y
CONFIG_CRYPTO_USER_API_SKCIPHER=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_DRBG=y

# ============================================================================
# RTC (DS3231 — CM4 IO board)
# ============================================================================
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_DS1307=y
CONFIG_RTC_DRV_BCM2835=y

# ============================================================================
# DMA & power management
# ============================================================================
CONFIG_DMADEVICES=y
CONFIG_DMA_BCM2835=y
CONFIG_PM=y
CONFIG_CPU_FREQ=y
CONFIG_THERMAL=y
CONFIG_BCM2711_THERMAL=y
CONFIG_CPU_THERMAL=y

# Continuous memory (CMA) — VideoCore, DMA buffers
CONFIG_CMA=y
CONFIG_DMA_CMA=y
CONFIG_CMA_SIZE_MBYTES=64

# ============================================================================
# systemd gereksinimleri
# ============================================================================
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y

CONFIG_INOTIFY_USER=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y
CONFIG_USER_NS=y
CONFIG_SYSFS=y
CONFIG_PROC_FS=y
CONFIG_FHANDLE=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y

# ============================================================================
# Networking — nftables, bridging, VLAN
# ============================================================================
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_VLAN_8021Q=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NFT_CT=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REJECT=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y

# IPv4/v6 filter
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y

# ============================================================================
# Kernel hardening (Faz 1: light, Faz 3: strict)
# ============================================================================
CONFIG_RANDOMIZE_BASE=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_DEBUG_WX=y
CONFIG_REFCOUNT_FULL=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y

# Faz 3'te aktive edilecek:
# CONFIG_SECURITY_LOCKDOWN_LSM=y
# CONFIG_LOCK_DOWN_KERNEL_FORCE_INTEGRITY=y
# CONFIG_MODULE_SIG_FORCE=y

# Debug minimum
# CONFIG_DEBUG_KERNEL=n  (kernel default'a bırak)
CONFIG_KALLSYMS=y
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y

# ============================================================================
# Audio (endüstriyel — kapalı)
# ============================================================================
# CONFIG_SOUND=n
# CONFIG_SND=n

# ============================================================================
# Graphics (headless — minimum framebuffer)
# ============================================================================
CONFIG_FB=y
CONFIG_FB_SIMPLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_LOGO=n
